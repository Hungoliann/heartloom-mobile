{
  "expo": {
    "name": "Heartloom",
    "slug": "heartloom-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF3E2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.heartloom.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Heartloom uses the camera to capture photos for your memory archive.",
        "NSPhotoLibraryUsageDescription": "Heartloom accesses your photo library to attach images to memories.",
        "NSMicrophoneUsageDescription": "Heartloom needs microphone access to record voice memories for your family.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF3E2"
      },
      "package": "com.heartloom.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-audio",
        {
          "microphonePermission": "Heartloom needs microphone access to record voice memories."
        }
      ],
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "heartloom",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57073d2b-8afb-4356-813a-17d8185b4689"
      }
    },
    "owner": "heartloom"
  }
}
