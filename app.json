{
  "expo": {
    "name": "Heartloom",
    "slug": "heartloom-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EDD6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.heartloom.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EDD6"
      },
      "package": "com.heartloom.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-av",
        { "microphonePermission": "Heartloom needs microphone access to record voice memories." }
      ]
    ],
    "scheme": "heartloom"
  }
}
